# Groq API — free tier at console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Models
# Recommended: llama-3.3-70b-versatile (best), llama-3.1-8b-instant (fastest)
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Embeddings — local sentence-transformers model (downloaded on first startup)
# 384-dim, ~90MB, runs on CPU
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Agent — max ReAct iterations (Groq free tier: keep at 1-2 to avoid rate limits)
MAX_AGENT_ITERATIONS=1
